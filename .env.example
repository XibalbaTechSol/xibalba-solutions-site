# Xibalba Solutions SMTP Configuration
# Use this to configure your self-hosted contact form handler.

# The SMTP server host (e.g., smtp.gmail.com or localhost)
SMTP_SERVER=localhost

# The SMTP server port (usually 587 for TLS or 25 for local)
SMTP_PORT=587

# Your SMTP username (if authentication is required)
SMTP_USER=

# Your SMTP password or App Password
SMTP_PASS=

# The email address that will appear in the "From" field
FROM_EMAIL=contact@xibalbasolutions.com
